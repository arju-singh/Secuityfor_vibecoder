# SentryScan configuration — copy to ".env" and adjust. NEVER commit a real .env.
# The server itself holds NO API keys; all secrets are read from the environment.

# Port the server listens on.
PORT=3000

# Allow scanning localhost / private addresses (your own dev servers). Off by
# default for SSRF protection; cloud-metadata IPs stay blocked regardless.
SENTRYSCAN_ALLOW_LOCAL=0

# Set when running behind a reverse proxy/load balancer so req.ip (and rate
# limiting) use the real client IP. Values: "true", a hop count, or "loopback".
# Leave UNSET when not behind a trusted proxy (prevents X-Forwarded-For spoofing).
# TRUST_PROXY=true

# Rate-limit tuning (defaults shown). Window is shared across limiters.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_API_MAX=120     # all /api requests per IP per window
RATE_LIMIT_SCAN_MAX=20     # website/API scans per IP per window
RATE_LIMIT_FILE_MAX=10     # code-upload scans per IP per window

# Per-suite scan timeouts — a single slow/hanging target can never stall a scan;
# the slow suite is marked "couldn't complete" and the rest of the report returns.
SCAN_SECTION_TIMEOUT_MS=30000
SCAN_RENDER_TIMEOUT_MS=55000   # headless-browser render gets longer

# --- CI / optional integrations (set as GitHub Actions secrets, not here) ----
# ANTHROPIC_API_KEY=   # enables AI PR review + @sentryscan chat
# SONAR_TOKEN=         # enables SonarCloud analysis

# GitHub token for repo scans — optional. Enables private repos and raises the
# rate limit for the "Scan a GitHub repo" feature. A classic PAT with "repo"
# scope (or fine-grained read-only Contents) is enough.
# GITHUB_TOKEN=ghp_xxx

# --- Export to Jira (create one issue per finding) ---------------------------
# The Jira export button works once these are set (or the user supplies them in
# the browser). Create an API token at https://id.atlassian.com/manage/api-tokens.
# The base URL is run through the same SSRF guard as scan targets.
# JIRA_BASE_URL=https://your-team.atlassian.net
# JIRA_EMAIL=you@your-team.com
# JIRA_API_TOKEN=xxx
# JIRA_PROJECT_KEY=SEC
# JIRA_MAX_ISSUES=25        # safety cap on issues created per export (default 25)

# --- Recurring scheduled scans (cron-ready) ----------------------------------
# Schedules persist server-side and run website/API/GitHub scans on a cadence,
# pushing each report to an optional webhook. Drive them EITHER way:
#   1. External cron (recommended — works even if the server sleeps). Point a
#      cron/GitHub Action at:  POST /api/schedule/run
#      with header  Authorization: Bearer $SCHEDULER_TOKEN
#      The endpoint refuses to run unless SCHEDULER_TOKEN is set (never open).
#   2. In-process timer (needs an always-on server): set ENABLE_SCHEDULER=1.
# SCHEDULER_TOKEN=change-me-to-a-long-random-string
# ENABLE_SCHEDULER=0          # 1 = also run a built-in timer (always-on hosts)
# SCHEDULER_TICK_MS=300000    # in-process check interval (default 5 min)
# SCHEDULE_MAX_PER_USER=25    # cap on schedules per account
# SCHEDULE_MAX_PER_RUN=25     # cap on scans executed per cron trigger

# --- Authentication (JWT cookie auth) ----------------------------------------
# REQUIRED in production: a long random secret for signing JWTs. If unset, a
# random one is generated and sessions reset on restart.
# JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_SECONDS=7200        # session length (2h)
REQUIRE_AUTH=0             # set to 1 to require login for the scan endpoints
REQUIRE_VERIFIED=0         # set to 1 to also require a verified email to scan (implies auth)
# Brute-force lockout tuning:
LOGIN_MAX_FAILS=5
LOGIN_WINDOW_MS=900000
LOGIN_LOCK_MS=900000
RATE_LIMIT_AUTH_MAX=12     # auth requests per IP per window

# --- Billing (Stripe Checkout) — use TEST keys until you go live -------------
# Endpoints skip cleanly until STRIPE_SECRET_KEY is set. Card data never touches
# this server (hosted Checkout). The webhook is the only thing that grants a plan.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx        # from `stripe listen` or the dashboard
# STRIPE_PRICE_PRO=price_xxx             # Stripe Price IDs for each tier
# STRIPE_PRICE_TEAM=price_xxx
# Customer self-service upgrade/downgrade/cancel uses the Stripe Billing Portal —
# enable it once at https://dashboard.stripe.com/test/settings/billing/portal

# --- Transactional email (email verification + password reset) ---------------
# Until RESEND_API_KEY is set, verification/reset links are LOGGED to the server
# console (dev mode) instead of emailed — the flows still work end-to-end locally.
# Get a key at https://resend.com. EMAIL_FROM must be a verified domain in prod.
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=SentryScan <noreply@your-domain.com>

# Absolute base URL used in email links. If unset, derived from the request host.
# APP_URL=https://your-domain.com

# --- Google OAuth ("Continue with Google") -----------------------------------
# Button is hidden until both are set. Create a "Web application" OAuth client at
# https://console.cloud.google.com/apis/credentials and add the redirect URI
# <APP_URL>/api/auth/google/callback (and the localhost equivalent for dev).
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# --- Analytics (loads only after cookie consent) -----------------------------
# provider: "plausible" (cookieless, recommended), "ga4", or a custom script.
# Plausible: set domain to your site domain. GA4: set domain to the G-XXXX id.
# ANALYTICS_PROVIDER=plausible
# ANALYTICS_DOMAIN=your-domain.com
# ANALYTICS_SRC=                          # optional custom/self-hosted script URL

# --- Support / contact -------------------------------------------------------
# Shown in the footer and used for the "Report a bug" link.
# SUPPORT_EMAIL=support@your-domain.com
